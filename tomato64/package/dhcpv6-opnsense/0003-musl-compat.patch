 int duid_type = 1;	/* DUID-LLT = 1 (default), DUID-LL = 3; set via -T */
 
+#ifdef TOMATO
+/*
+ * The upstream fork assumes the platform libc provides the BSD arc4random
+ * family. musl (and some others) do not, so supply a minimal, unbiased
+ * arc4random_uniform() backed by getentropy() when building for Tomato64.
+ */
+uint32_t
+arc4random_uniform(uint32_t upper_bound)
+{
+	uint32_t r, min;
+
+	if (upper_bound < 2)
+		return (0);
+
+	min = -upper_bound % upper_bound;	/* 2^32 % upper_bound */
+	for (;;) {
+		if (getentropy(&r, sizeof(r)) != 0)
+			r = (uint32_t)random();	/* fallback, non-fatal */
+		if (r >= min)
+			return (r % upper_bound);
+	}
+}
+#endif /* TOMATO */
+
 static int dhcp6_count_list(struct dhcp6_list *);
 static int in6_matchflags(struct sockaddr *, char *, int);
 static ssize_t dnsencode(const char *, char *, size_t);
