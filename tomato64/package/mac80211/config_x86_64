# x86_64-specific mac80211 backports config for Tomato64
#
# Appended after config_base for x86_64 builds only.
#
# Intel iwlwifi driver support. Filenames and versions for firmware are sourced
# from OpenWrt: package/firmware/linux-firmware/intel.mk
# When bumping the mac80211 backports version, check OpenWrt's intel.mk at the
# matching tag for any driver changes (e.g. IWLMLD added in v25.12.0-rc5).
#
# Reference: OpenWrt package/kernel/mac80211/intel.mk

CPTCFG_IWLWIFI=m
CPTCFG_IWLDVM=m
CPTCFG_IWLMVM=m
CPTCFG_IWLMLD=m
