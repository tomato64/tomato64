#!/bin/sh

set -e

root=$(rdev | awk '{print $1}')

if [[ ${root:5:2} == "sd" ]] || [[ ${root:5:2} == "vd" ]]; then
        root1=${root:0:8}
        root2=${root:8:1}
fi

if [[ ${root:5:4} == "nvme" ]] || [[ ${root:5:3} == "mmc" ]]; then
        root1=${root:0:12}
        root2=${root:13:1}
fi

if [ -z "$root1" ] || [ -z "$root2" ]; then
        echo "expand_root_partition: unrecognized root device '$root', skipping" >&2
        exit 0
fi

growpart $root1 $root2
resize2fs $root
