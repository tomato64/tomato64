#!/bin/sh
#
# tomato64-sysupgrade-bcm53xx - BCM53XX launcher for the OpenWrt sysupgrade
# flow. Modeled on the GL-MT3600BE launcher (tomato64-sysupgrade), but the
# BCM53XX firmware artifact is a Broadcom TRX (kernel + appended UBI), not an
# OpenWrt sysupgrade tar, so validation is otrx-based and the handoff lands in
# OpenWrt's stock bcm53xx platform.sh -> platform_do_upgrade_nand_trx ->
# nand_do_upgrade.
#
# This replaces the old whole-image "mtd -e firmware write -" path. Instead of
# blindly erasing the firmware partition and writing kernel+UBI in one raw
# pass (OpenWrt's discouraged fallback that resets all UBI erase counters and
# wipes rootfs_data), we:
#   - validate the TRX before touching flash,
#   - back up /nvram so settings survive the upgrade,
#   - release pid1's squashfs mmap (so nand can free the rootfs ubiblock),
#   - hand off to stage2 -> nand_do_upgrade, which writes a kernel-only TRX to
#     "firmware" and ubiformat's only the rootfs UBI volume, preserving erase
#     counters and the rootfs_data overlay.
#
# MUST be started detached (caller uses `setsid ... &`) so stage2's
# kill_remaining sees pid1 as our parent and skips us while killing httpd.
#
# $1 = Broadcom TRX image (already in tmpfs).
# $2 = "1" -> factory reset; anything else -> keep /nvram.

IMG="$1"
RESET="${2:-0}"

CONF_TGZ="/tmp/sysupgrade.tgz"

log() { echo "tomato64-sysupgrade: $*" > /dev/console 2>/dev/null; echo "tomato64-sysupgrade: $*"; }

# Wait for the glue to exit so we are reparented to init (pid 1) before
# anything destructive, and so httpd can finish showing the wait page.
sleep 3

if [ -z "$IMG" ] || [ ! -s "$IMG" ]; then
	log "ERROR: missing or empty image '$IMG' - aborting, system untouched"
	exit 1
fi

# Validate it's a real TRX with a recoverable kernel+rootfs before we erase a
# single block (replaces OpenWrt's platform_check_image / fwtool metadata).
# otrx check is trailer-tolerant and verifies the TRX CRC.
if ! otrx check "$IMG" >/dev/null 2>&1; then
	log "ERROR: '$IMG' is not a valid Broadcom TRX (otrx check failed)"
	log "Upload a tomato64 bcm53xx *.trx - aborting, system untouched"
	rm -f "$IMG"
	exit 1
fi
log "validated Broadcom TRX image"

# board_name/model so OpenWrt's bcm53xx platform.sh case-match resolves to the
# default (TRX) path instead of a Meraki NAND special-case. Tomato64 does not
# populate /tmp/sysinfo at preinit, so seed it from the device tree (matches
# OpenWrt's 03_init_board).
mkdir -p /tmp/sysinfo
if [ ! -s /tmp/sysinfo/board_name ]; then
	if [ -r /proc/device-tree/compatible ]; then
		tr '\0' '\n' < /proc/device-tree/compatible | head -n1 > /tmp/sysinfo/board_name
	fi
	[ -s /tmp/sysinfo/board_name ] || echo "broadcom,bcm53xx" > /tmp/sysinfo/board_name
fi
if [ ! -s /tmp/sysinfo/model ]; then
	if [ -r /proc/device-tree/model ]; then
		tr -d '\0' < /proc/device-tree/model > /tmp/sysinfo/model
	fi
	[ -s /tmp/sysinfo/model ] || echo "Broadcom BCM53XX" > /tmp/sysinfo/model
fi
log "board $(cat /tmp/sysinfo/board_name) / $(cat /tmp/sysinfo/model)"

# Back up /nvram (the live overlay-merged view). Survives the ramfs pivot
# because supivot mount-moves /tmp. Consumed by our nand_restore_config, which
# stages it at the rootfs_data root for the init.c boot hook to extract.
rm -f "$CONF_TGZ"
if [ "$RESET" = "1" ]; then
	log "factory reset requested - settings will NOT be preserved"
elif [ -d /nvram ]; then
	tar -czf "$CONF_TGZ" -C / nvram 2>/dev/null
	if [ -s "$CONF_TGZ" ]; then
		log "config backup staged ($(wc -c < "$CONF_TGZ") bytes)"
	else
		rm -f "$CONF_TGZ"
		log "WARNING: could not back up /nvram - settings will reset"
	fi
fi

# Disable rc's check_services() watchdog so kill_remaining doesn't loop on
# respawned daemons. Equivalent of OpenWrt's `ubus call service delete` loop.
# Must happen AFTER the backup above so the flag doesn't end up in restored
# /nvram.
nvram set g_upgrade=1
log "supervisor respawn disabled (g_upgrade=1)"

# Re-exec pid1 (rc) into a static stub in tmpfs to drop its /romfs mmaps -
# until those go away, the squashfs superblock keeps the rootfs ubiblock
# claimed and nand_upgrade_prepare_ubi's ubiblock_remove returns EBUSY.
# Equivalent of OpenWrt procd's "chroot prefix; execvp /sbin/upgraded".
# Static is load-bearing: a dynamic stub re-mmaps /romfs/lib/libc.so via
# PT_INTERP.
STUB_SRC=/sbin/tomato64-init-stub
STUB_DST=/tmp/tomato64-init-stub
if [ ! -x "$STUB_SRC" ]; then
	log "ERROR: $STUB_SRC missing - cannot release pid1 squashfs mmap; aborting"
	rm -f "$IMG" "$CONF_TGZ"
	exit 1
fi
cp "$STUB_SRC" "$STUB_DST" && chmod 0755 "$STUB_DST"
log "signalling pid1 (rc) to re-exec into $STUB_DST"
# SIGURG (=23) is unused by rc and not in initsigs; SIGRTMIN would be silently
# swallowed by musl (it reserves signals 32-34 internally).
kill -23 1 2>/dev/null
i=0
while [ "$i" -lt 10 ]; do
	[ "$(readlink /proc/1/exe 2>/dev/null)" = "$STUB_DST" ] && break
	sleep 1
	i=$((i + 1))
done
if [ "$(readlink /proc/1/exe 2>/dev/null)" = "$STUB_DST" ]; then
	log "pid1 re-exec confirmed - squashfs reference dropped"
else
	log "ERROR: pid1 did not re-exec (/proc/1/exe still '$(readlink /proc/1/exe 2>/dev/null)'); aborting"
	rm -f "$IMG" "$CONF_TGZ"
	exit 1
fi

# Hand off to the stock OpenWrt stage2 -> do_stage2 -> platform_do_upgrade ->
# (bcm53xx) platform_do_upgrade_nand_trx -> nand_do_upgrade -> our
# nand_restore_config override -> reboot. We exec so the surviving process IS
# stage2 (ppid = init). CI_* are left at nand.sh defaults; bcm53xx platform.sh
# writes the kernel TRX itself and passes only the rootfs UBI to
# nand_do_upgrade.
log "handing off to OpenWrt stage2 (RAM pivot + nand flash)"
exec /lib/upgrade/stage2 "$IMG" /lib/upgrade/do_stage2

log "ERROR: failed to exec /lib/upgrade/stage2"
exit 1
